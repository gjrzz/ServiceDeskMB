// Prisma Schema para Central de Atendimento Monte Bravo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

enum Perfil {
  ADMIN
  USUARIO
}

model Usuario {
  id            String   @id @default(cuid())
  nome          String
  email         String   @unique
  senha         String
  perfil        Perfil   @default(USUARIO)
  departamento  String
  avatar        String   // Iniciais
  avatarUrl     String?  // URL da foto
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  // Relações
  chamadosCriados      Chamado[]         @relation("ChamadosSolicitante")
  chamadosAtribuidos   Chamado[]         @relation("ChamadosResponsavel")
  atividades           AtividadeChamado[]
  artigosCriados       ArtigoKB[]        @relation("ArtigoAutor")
  artigosAtualizados   ArtigoKB[]        @relation("ArtigoEditor")
  notificacoes         Notificacao[]
  refreshTokens        RefreshToken[]
  logsAuditoria        LogAuditoria[]

  @@index([email])
  @@index([ativo])
  @@map("usuarios")
}

model RefreshToken {
  id           String   @id @default(cuid())
  token        String   @unique
  usuarioId    String
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  criadoEm     DateTime @default(now())

  @@index([usuarioId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================
// CHAMADOS
// ============================================

enum Prioridade {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

enum StatusChamado {
  ABERTO
  EM_ANDAMENTO
  AGUARDANDO_APROVACAO
  AGUARDANDO
  RESOLVIDO
  FECHADO
  CONTESTADO
}

enum Categoria {
  HARDWARE
  SOFTWARE
  REDE
  ACESSO
  OUTROS
}

model Chamado {
  id              String         @id @default(cuid())
  titulo          String
  descricao       String         @db.Text
  prioridade      Prioridade     @default(MEDIO)
  status          StatusChamado  @default(ABERTO)
  categoria       Categoria
  
  // Relacionamentos
  solicitanteId   String
  solicitante     Usuario        @relation("ChamadosSolicitante", fields: [solicitanteId], references: [id])
  
  responsavelId   String?
  responsavel     Usuario?       @relation("ChamadosResponsavel", fields: [responsavelId], references: [id])
  
  // SLA
  slaHoras        Int            @default(24)
  slaVencimento   DateTime?
  slaCumprido     Boolean?
  
  // Avaliação
  avaliacaoNota         Int?
  avaliacaoResolvido    Boolean?
  avaliacaoComentario   String?        @db.Text
  avaliacaoData         DateTime?
  avaliacaoIgnorada     Boolean        @default(false)
  
  // Timestamps
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt
  resolvidoEm     DateTime?
  fechadoEm       DateTime?
  
  // Relações
  atividades      AtividadeChamado[]
  anexos          Anexo[]

  @@index([solicitanteId])
  @@index([responsavelId])
  @@index([status])
  @@index([prioridade])
  @@index([categoria])
  @@index([criadoEm])
  @@map("chamados")
}

// ============================================
// ATIVIDADES E HISTÓRICO
// ============================================

enum TipoAtividade {
  COMENTARIO
  COMENTARIO_INTERNO
  MUDANCA_STATUS
  MUDANCA_PRIORIDADE
  ATRIBUICAO
  CONTESTACAO
  REANALISE
  AVALIACAO
}

model AtividadeChamado {
  id          String         @id @default(cuid())
  chamadoId   String
  chamado     Chamado        @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  
  autorId     String
  autor       Usuario        @relation(fields: [autorId], references: [id])
  
  tipo        TipoAtividade
  texto       String         @db.Text
  
  // Metadados para mudanças
  valorAnterior String?
  valorNovo     String?
  
  criadoEm    DateTime       @default(now())

  @@index([chamadoId])
  @@index([autorId])
  @@index([criadoEm])
  @@map("atividades_chamado")
}

// ============================================
// ANEXOS
// ============================================

model Anexo {
  id          String   @id @default(cuid())
  chamadoId   String
  chamado     Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  
  nomeOriginal String
  nomeArquivo  String  // Nome único no servidor
  tamanho      Int     // Em bytes
  mimeType     String
  url          String
  
  criadoEm    DateTime @default(now())

  @@index([chamadoId])
  @@map("anexos")
}

// ============================================
// BASE DE CONHECIMENTO
// ============================================

model ArtigoKB {
  id          String   @id @default(cuid())
  titulo      String
  conteudo    String   @db.Text
  categoria   String
  tags        String[] // Array de tags
  
  autorId     String
  autor       Usuario  @relation("ArtigoAutor", fields: [autorId], references: [id])
  
  editorId    String?
  editor      Usuario? @relation("ArtigoEditor", fields: [editorId], references: [id])
  
  visualizacoes Int    @default(0)
  util          Int    @default(0)
  naoUtil       Int    @default(0)
  
  publicado   Boolean  @default(false)
  
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([autorId])
  @@index([publicado])
  @@index([categoria])
  @@map("artigos_kb")
}

// ============================================
// NOTIFICAÇÕES
// ============================================

enum TipoNotificacao {
  CHAMADO_CRIADO
  CHAMADO_ATUALIZADO
  CHAMADO_RESOLVIDO
  COMENTARIO_ADICIONADO
  STATUS_ALTERADO
  PRIORIDADE_ALTERADA
  KB_CRIADO
  KB_EDITADO
  USUARIO_CRIADO
  SOLICITAR_AVALIACAO
}

model Notificacao {
  id          String           @id @default(cuid())
  tipo        TipoNotificacao
  titulo      String
  mensagem    String
  
  linkTipo    String?          // 'chamado', 'artigo', 'usuario'
  linkId      String?
  
  destinatarioId String
  destinatario   Usuario       @relation(fields: [destinatarioId], references: [id], onDelete: Cascade)
  
  lida        Boolean          @default(false)
  criadoEm    DateTime         @default(now())

  @@index([destinatarioId])
  @@index([lida])
  @@index([criadoEm])
  @@map("notificacoes")
}

// ============================================
// AUDITORIA
// ============================================

enum AcaoAuditoria {
  LOGIN
  LOGOUT
  CRIAR_USUARIO
  EDITAR_USUARIO
  DESATIVAR_USUARIO
  EXCLUIR_USUARIO
  CRIAR_CHAMADO
  EDITAR_CHAMADO
  EXCLUIR_CHAMADO
  CRIAR_ARTIGO
  EDITAR_ARTIGO
  EXCLUIR_ARTIGO
  ALTERAR_CONFIGURACAO
}

model LogAuditoria {
  id          String         @id @default(cuid())
  usuarioId   String
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])
  
  acao        AcaoAuditoria
  descricao   String
  
  // Metadados
  ip          String?
  userAgent   String?
  dadosAntes  Json?          // Estado anterior (para edições)
  dadosDepois Json?          // Estado novo
  
  criadoEm    DateTime       @default(now())

  @@index([usuarioId])
  @@index([acao])
  @@index([criadoEm])
  @@map("logs_auditoria")
}
